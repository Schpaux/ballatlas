# ============================================================
# BallAtlas — Environment Variables
# ============================================================
# Copy to .env.local and fill in values.
# Run `vercel env pull apps/web/.env.local` to pull from Vercel.
#
# Local Supabase values: run `supabase status` to see them.
# ============================================================

# Supabase — public (safe to expose to browser)
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Supabase — server only (NEVER expose to client)
SUPABASE_SERVICE_ROLE_KEY=

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
