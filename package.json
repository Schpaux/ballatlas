{
  "name": "ballatlas",
  "private": true,
  "version": "0.0.1",
  "description": "The most comprehensive golf ball registry and intelligence platform",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "lint:fix": "turbo run lint -- --fix",
    "type-check": "turbo run type-check",
    "test": "turbo run test",
    "clean": "turbo run clean && rm -rf node_modules",
    "format": "prettier --write \"**/*.{ts,tsx,md,json,css}\" --ignore-path .prettierignore",
    "format:check": "prettier --check \"**/*.{ts,tsx,md,json,css}\" --ignore-path .prettierignore",
    "prepare": "husky",
    "supabase:types": "supabase gen types typescript --local > packages/database/src/types.generated.ts",
    "import:balls": "tsx packages/golfball-data/scripts/import.ts",
    "validate:balls": "tsx packages/golfball-data/scripts/validate.ts",
    "dataset:report": "tsx packages/golfball-data/scripts/report.ts"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.6.0",
    "@commitlint/config-conventional": "^19.6.0",
    "husky": "^9.1.7",
    "lint-staged": "^15.4.0",
    "prettier": "^3.4.2",
    "prettier-plugin-tailwindcss": "^0.6.9",
    "turbo": "^2.4.4",
    "typescript": "^5.7.3"
  },
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  }
}
